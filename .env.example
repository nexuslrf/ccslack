# Slack Bot Token (xoxb-..., required)
# From your Slack app's OAuth & Permissions page
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Slack App-Level Token (xapp-..., required for Socket Mode)
# Generate via your Slack app's "Basic Information" → "App-Level Tokens"
# Needs the `connections:write` scope.
SLACK_APP_TOKEN=xapp-your-app-token-here

# Meta channel ID (required)
# Private channel where session management commands live.
# Right-click channel → View channel details → bottom shows Channel ID.
SLACK_META_CHANNEL_ID=C0123456789

# Where session management lives (optional, default "channel"):
#   channel — meta channel only (current behaviour, no change on upgrade)
#   hybrid  — meta channel AND the bot's DM both accept /ccslack commands
#   dm      — the bot's DM only
# Commands & dashboard buttons honour this; proactive notifications (join
# offers, SSH prompts) still post to the meta channel for now. For DM modes,
# enable the app's Messages tab (see slack-app-manifest.yaml app_home).
# CCSLACK_META_SURFACE=channel

# Allowed Slack user IDs (comma-separated, required)
# Workspace member IDs (U...) — same place as channel IDs.
ALLOWED_USERS=U0123456789,U0987654321

# ── Slash command ────────────────────────────────────────────────────────────
# The slash command the bot listens for in the meta channel. Must match the
# command you registered in the Slack app config exactly. Set this if
# `/ccslack` collides with another app in your workspace.
# CCSLACK_SLASH_COMMAND=/ccslack

# HTTP(S) proxy for all Slack traffic (Socket Mode WebSocket + Web API). Must be
# http(s):// — the Slack SDK can't do SOCKS and ignores *_PROXY env vars. For a
# SOCKS upstream, front it with a SOCKS→HTTP bridge, or wrap the process in
# proxychains instead. Applies to the router and every worker.
# CCSLACK_PROXY=http://127.0.0.1:8080

# Prefix for auto-created channel names ("<prefix>-<cwd-slug>"). Leave empty to
# use just the cwd slug (e.g. "vrender" instead of "ccslack-vrender").
# CCSLACK_CHANNEL_PREFIX=ccslack

# Offer a button to render markdown tables in agent answers as an image
# (Slack renders tables poorly). Raw text is always posted. Set false to hide.
# CCSLACK_TABLE_RENDER=true

# After /ccslack new, post a Join button in the meta channel so other
# ALLOWED_USERS can opt into the new private session channel. Set false to skip.
# CCSLACK_JOIN_OFFER=true

# Public-channel ("office") mode. When true, ccslack creates PUBLIC session
# channels and STOPS trusting channel membership for auth (a public channel
# anyone can join must not grant terminal access). Auth becomes ALLOWED_USERS
# + per-channel `/ccslack adduser` grants. Needs channels:manage /
# channels:history / channels:read scopes and the message.channels event
# (instead of the groups:* equivalents). NOTE: agent output, /send files, and
# screenshots become visible to the whole workspace. Default false (private).
# CCSLACK_PUBLIC_CHANNELS=false

# ── Multi-host (router + workers) ────────────────────────────────────────────
# Opt-in: drive sessions on several machines from one Slack app + meta channel.
# One process is the router (holds the Slack connection); others are workers
# (run tmux locally). Empty CCSLACK_WORKERS => `ccslack router` == standalone.
# Full guide: docs/multi-host.md. Tip: give each role its own dir + .env via
#   ccslack --config-dir /etc/ccslack/<role> {router|worker}
#
# Shared (identical on every host): SLACK_BOT_TOKEN, SLACK_META_CHANNEL_ID,
#   ALLOWED_USERS, CCSLACK_SLASH_COMMAND, CCSLACK_PUBLIC_CHANNELS.
# SLACK_APP_TOKEN is ROUTER-ONLY — a worker receives forwarded events and runs
#   without it.
#
# CCSLACK_HOST — this machine's name in the fleet (default: hostname). Shown in
#   `/ccslack list` and targeted by `/ccslack new --host <name>`.
#   IMPORTANT: a worker's CCSLACK_HOST must EXACTLY match the key it's given in
#   the router's CCSLACK_WORKERS list, or `--host <key>` is rejected by that
#   worker. The key is just a label — it need not be a real/resolvable hostname.
# CCSLACK_HOST=

# CCSLACK_LINK_PORT — localhost port the worker's link server listens on; the
#   router reaches it through the SSH tunnel, so it's never exposed on the
#   network. Change only on a port clash (must match the worker's actual port).
# CCSLACK_LINK_PORT=8765

# CCSLACK_WORKERS — ROUTER ONLY. Comma-separated `host=ssh_target` entries.
#   `host` is the fleet label (== that worker's CCSLACK_HOST); `ssh_target` is
#   whatever `ssh <target>` resolves (a ~/.ssh/config alias or user@host).
# CCSLACK_WORKERS=gpu1=user@gpu1.example.com,gpu2=gpu2-alias

# CCSLACK_FLEET_NOTIFY (router) — post host connect/disconnect lines to the meta
#   channel. Default off; check status on demand with `/ccslack fleet`.
# CCSLACK_FLEET_NOTIFY=false

# SSH interactive auth (router) — run tunnels under a PTY and bridge auth
#   prompts (e.g. Duo 2FA) to the meta channel for a Slack-side response,
#   instead of answering at the console. Tune CCSLACK_SSH_PROMPT_RE to your
#   server's prompt wording (regex, searched against the prompt tail).
# CCSLACK_SSH_INTERACTIVE=false
# CCSLACK_SSH_PROMPT_RE=(?i)(passcode|password|verification code|two-factor|duo|option).*:\s*$
#
# Example — router host .env:   (also runs sessions for itself as "router0")
#   SLACK_APP_TOKEN=xapp-...
#   CCSLACK_HOST=router0
#   CCSLACK_WORKERS=gpu1=user@gpu1,gpu2=user@gpu2
# Example — gpu1 worker .env:   (no SLACK_APP_TOKEN)
#   CCSLACK_HOST=gpu1

# ── Tmux ─────────────────────────────────────────────────────────────────────
# CCSLACK_TMUX_SESSION=ccslack

# ── Config directory ─────────────────────────────────────────────────────────
# CCSLACK_DIR=~/.ccslack

# ── Default provider ─────────────────────────────────────────────────────────
# CCSLACK_PROVIDER=claude   # claude | codex | gemini | pi | shell

# ── Startup recovery (after reboot / tmux restart) ───────────────────────────
# What to do when a bound channel's tmux window is gone at startup:
#   banner   (default) — post a manual Fresh/Continue/Resume/Archive banner
#   continue — auto-respawn the agent and continue its latest session
#   resume   — auto-respawn with the remembered session id (falls back to continue)
#   off      — do nothing (polling still posts the banner later)
# CCSLACK_RESTORE_ON_START=banner

# Per-provider launch command overrides:
# CCSLACK_CLAUDE_COMMAND=my-claude-wrapper
# CCSLACK_CODEX_COMMAND=my-codex-wrapper
# CCSLACK_GEMINI_COMMAND=my-gemini-wrapper

# Claude config dir (for Claude wrappers like ce, cc-mirror, zai):
# CLAUDE_CONFIG_DIR=~/.claude-custom

# ── Status display ───────────────────────────────────────────────────────────
# CCSLACK_STATUS_MODE=system   # system (green=working) | user (green=ready)
# CCSLACK_HIDE_TOOL_CALLS=true

# Group a turn's tool_use/tool_result/thinking under one threaded parent in
# the main channel (keeps long tool chains out of the way). Plain answers and
# interactive prompts stay in the main channel. Per-channel: /ccslack thread.
# CCSLACK_THREAD_TOOL_CALLS=true

# ── LLM (optional, for shell command generation + completion summaries) ─────
# CCSLACK_LLM_PROVIDER=openai   # openai | xai | deepseek | anthropic | groq | ollama
# CCSLACK_LLM_API_KEY=
# CCSLACK_LLM_MODEL=
# CCSLACK_LLM_TEMPERATURE=0.1

# ── Voice transcription (optional) ───────────────────────────────────────────
# CCSLACK_WHISPER_PROVIDER=groq   # openai | groq
# GROQ_API_KEY=gsk_...
